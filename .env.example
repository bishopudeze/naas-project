# ════════════════════════════════════════════════════════════════
#  NAAS — Environment Variables
#  Copy this file to .env and fill in your real values.
#  NEVER commit .env to Git — it's already in .gitignore
# ════════════════════════════════════════════════════════════════

# ── Firebase (get from Firebase Console → Project Settings) ──────
VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
VITE_FIREBASE_APP_ID=1:123456789:web:abcdef
VITE_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX
VITE_FIREBASE_VAPID_KEY=your_vapid_key_here

# ── Anthropic Claude API ─────────────────────────────────────────
# For production: use a Cloud Function proxy instead of exposing this
VITE_ANTHROPIC_KEY=sk-ant-your-key-here

# ── Termii SMS (Nigerian SMS gateway) ───────────────────────────
# For production: store only in Firebase Cloud Functions config
# firebase functions:config:set termii.key="your-termii-api-key"
VITE_TERMII_KEY=your_termii_key_here

# ── Feature flags ────────────────────────────────────────────────
# Set to "true" to use live Firebase instead of the mock database
VITE_USE_FIREBASE=false
